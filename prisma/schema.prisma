generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// The B2B developer using VREN to monetize their protocol.
/// Primary authentication is via wallet (SIWE). Email is optional (for notifications).
model Developer {
  id        String   @id @default(cuid())
  wallet    String   @unique // Primary identifier — the EVM address (checksummed, EIP-55)
  email     String?  @unique // Optional — can be linked later for notifications
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apps    App[]
  apiKeys ApiKey[]

  @@index([wallet])
}

/// Represents a registered application / protocol in the VrenRegistry.
model App {
  id           String   @id @default(cuid())
  contractId   String?  @unique // bytes32 appId from VrenRegistry.sol (null = not yet deployed on-chain)
  name         String
  payoutWallet String   // The wallet receiving USDC fees
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  developerId String
  developer   Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

  plans        Plan[]
  subscribers  Subscriber[]
  transactions Transaction[]

  @@index([contractId])
  @@index([developerId])
}

/// Represents an available subscription tier for an App.
model Plan {
  id         String   @id @default(cuid())
  onchainIdx Int      // The integer planId in the VrenSubscription contract
  name       String
  price      String   // Stored as string to handle BigInt precision (USDC amounts)
  duration   Int      // Duration in seconds
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  appId String
  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  subscribers  Subscriber[]
  transactions Transaction[]

  @@unique([appId, onchainIdx])
}

/// Off-chain cache of end-users who have minted a subscription NFT.
model Subscriber {
  id        String   @id @default(cuid())
  wallet    String   // End-user EVM address
  tokenId   String?  @unique // The ERC-1155 NFT token ID (if minted)
  expiry    DateTime // The absolute expiry date of the subscription
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appId String
  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  @@unique([appId, wallet])
  @@index([wallet])
}

/// Idempotency table for Webhook Reliability. Prevents processing the same transaction twice.
model WebhookEvent {
  id              String   @id @default(cuid())
  transactionHash String   @unique // The tx hash from Polygon
  eventType       String   // e.g., 'Subscribed', 'PlanCreated'
  processedAt     DateTime @default(now())

  @@index([transactionHash])
}

/// Hashed API keys for developer server-to-server authentication.
model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique // SHA-256 hash of the actual key
  keyPrefix  String              // First ~16 chars for display (e.g., "vren_live_0a1b2c")
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  developerId String
  developer   Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

  @@index([developerId])
}

/// On-chain subscription events mirrored for dashboard display.
model Transaction {
  id              String   @id @default(cuid())
  transactionHash String   @unique
  type            String   // 'new_subscription' | 'renewal' | 'cancelled'
  usdcAmount      String?  // USDC amount in 6-decimal string (e.g. "19000000" = $19.00)
  wallet          String   // end-user EVM address
  tokenId         String?
  createdAt       DateTime @default(now())

  appId  String
  app    App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  planId String?
  plan   Plan?   @relation(fields: [planId], references: [id])

  @@index([appId])
  @@index([wallet])
}
